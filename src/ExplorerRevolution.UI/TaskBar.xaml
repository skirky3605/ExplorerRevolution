<Page
    x:Class="ExplorerRevolution.UI.TaskBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:data="using:ExplorerRevolution.Data"
    xmlns:local="using:ExplorerRevolution.UI"
    xmlns:managedShell="using:ManagedShell.WindowsTasks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="TaskBarPage"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid
            Name="TaskBarGrid"
            Height="48"
            Background="{ThemeResource SystemControlAltHighAcrylicElementBrush}"
            CornerRadius="1"
            Loaded="TaskBarGrid_Loaded">
            <Button
                Height="2"
                Margin="0,0,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="2"
                CornerRadius="0"
                IsEnabled="False" />
            <StackPanel
                Name="TaskBarStack"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <StackPanel.Transitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.Transitions>
            </StackPanel>

            <GridView
                Name="TaskBarItemsControl"
                Height="64"
                Margin="0,1,220,1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                AllowDrop="True"
                CanReorderItems="True"
                IsItemClickEnabled="True"
                ItemClick="TaskBarItemsControl_ItemClick"
                Loaded="TaskBarItemsControl_Loaded"
                ScrollViewer.BringIntoViewOnFocusChange="False"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.HorizontalScrollMode="Auto"
                ScrollViewer.IsVerticalRailEnabled="False"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollMode="Disabled"
                SelectionChanged="TaskBarItemsControl_SelectionChanged"
                SelectionMode="Extended"
                ShowsScrollingPlaceholders="False">

                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition IsStaggeringEnabled="False" />
                        <PopupThemeTransition />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="GridViewItem">
                                    <GridViewItemPresenter
                                        x:Name="Root"
                                        Margin="0,1,0,-2"
                                        CornerRadius="8"
                                        DragBackground="Transparent" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            Height="48"
                            Margin="220,0,0,8"
                            HorizontalAlignment="Center"
                            CornerRadius="1"
                            Orientation="Horizontal"
                            Spacing="0">
                            <StackPanel.Transitions>
                                <TransitionCollection>
                                    <RepositionThemeTransition />
                                    <PaneThemeTransition />
                                </TransitionCollection>
                            </StackPanel.Transitions>
                        </StackPanel>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="managedShell:ApplicationWindow">
                        <Grid
                            Height="40"
                            MaxWidth="128"
                            Margin="6,0,6,1"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            CornerRadius="0">
                            <StackPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                                <Image
                                    Width="24"
                                    Height="24"
                                    Margin="4,0,1,1"
                                    HorizontalAlignment="Center"
                                    Source="{x:Bind Icon}" />
                                <TextBlock
                                    Margin="4,0,0,2"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind Title}"
                                    Visibility="Collapsed" />
                            </StackPanel>
                            <ToggleButton
                                Width="24"
                                Height="12"
                                Margin="0,0,0,1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource AccentFillColorDisabledBrush}"
                                CornerRadius="8"
                                IsTabStop="False">

                                <ToggleButton.RenderTransform>
                                    <ScaleTransform CenterX="12" CenterY="12" ScaleX="0.3333" ScaleY="0.25" />
                                </ToggleButton.RenderTransform>
                            </ToggleButton>
                            <Grid
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent" />
                            <Button
                                Margin="-6,-1,-6,-1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                ClickMode="Hover"
                                CornerRadius="8"
                                IsTabStop="False"
                                Opacity="0.8" />
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <Grid Name="TbLeftBottomArea" HorizontalAlignment="Left">
                <StackPanel
                    Name="TbRbLeftBottomAreaStk"
                    Margin="4,0,4,0"
                    VerticalAlignment="Stretch">
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="左下角预留空间"
                        Visibility="Collapsed" />
                </StackPanel>
            </Grid>
            <StackPanel
                Name="TaskBarRightBottomStack"
                Height="48"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">

                <Grid Name="TbRbBkgAppArea" Width="36">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Grid.Transitions>
                    <Button
                        Name="Button_TbRbBkgAppArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="12"
                        Glyph="&#xE010;">
                        <FontIcon.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <RotateTransform />
                            </TransformGroup>
                        </FontIcon.RenderTransform>

                    </FontIcon>
                    <Button
                        Name="Button_TbRbBkgAppArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbBkgAppArea_Front_Click"
                        CornerRadius="8"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbKeyBoardArea">
                    <StackPanel
                        Name="TbRbKeyBoardAreaStk"
                        Margin="4,0,4,0"
                        VerticalAlignment="Stretch">
                        <TextBlock VerticalAlignment="Center" Text="拼" />
                    </StackPanel>
                </Grid>
                <Grid Name="TbRbStatusArea">
                    <Button
                        Name="Button_TbRbStatusArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <StackPanel
                        Name="TbRbStatusAreaStk"
                        Margin="6,0,6,0"
                        VerticalAlignment="Stretch">
                        <TextBlock VerticalAlignment="Center" Text="控制中心" />
                    </StackPanel>
                    <Button
                        Name="Button_TbRbStatusArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbStatusArea_Front_Click"
                        CornerRadius="8"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbTimeArea" Width="76">
                    <Button
                        Name="Button_TbRbTimeArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <TextBlock
                        Name="TbRbTime"
                        Margin="0,0,11,25"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        FontSize="12"
                        Text="00:00" />
                    <TextBlock
                        Name="TbRbDate"
                        Margin="0,0,11,9"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        FontSize="12"
                        Text="2026/1/1" />
                    <Button
                        Name="Button_TbRbTimeArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbTimeArea_Front_Click"
                        CornerRadius="8"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbShowDskArea" Width="8">
                    <Button
                        Name="Button_TbRbShowDskArea_Front"
                        Margin="0,2,-1,-1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbShowDskArea_Front_Click"
                        CornerRadius="0"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.8"
                        ToolTipService.ToolTip="显示桌面" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
