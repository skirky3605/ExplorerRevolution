<Page
    x:Class="ExplorerRevolution.UI.TaskBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ExplorerRevolution.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid
            Name="TaskBarGrid"
            Height="48"
            Background="{ThemeResource SystemControlAcrylicElementBrush}"
            CornerRadius="1"
            Loaded="TaskBarGrid_Loaded">
            <Button
                Height="2"
                Margin="0,0,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="2"
                CornerRadius="0"
                IsEnabled="False" />
            <StackPanel
                Name="TaskBarStack"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">
                <StackPanel.Transitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.Transitions>

            </StackPanel>
            <Grid Name="TbLeftBottomArea">
                <StackPanel
                    Name="TbRbLeftBottomAreaStk"
                    Margin="4,0,4,0"
                    VerticalAlignment="Stretch">
                    <TextBlock VerticalAlignment="Center" Text="左下角预留空间" />
                </StackPanel>
            </Grid>
            <StackPanel
                Name="TaskBarRightBottomStack"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">

                <Grid Name="TbRbBkgAppArea" Width="36">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Grid.Transitions>
                    <Button
                        Name="Button_TbRbBkgAppArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="12"
                        Glyph="&#xE010;">
                        <FontIcon.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <RotateTransform />
                            </TransformGroup>
                        </FontIcon.RenderTransform>

                    </FontIcon>
                    <Button
                        Name="Button_TbRbBkgAppArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbBkgAppArea_Front_Click"
                        CornerRadius="8"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbKeyBoardArea">
                    <StackPanel
                        Name="TbRbKeyBoardAreaStk"
                        Margin="4,0,4,0"
                        VerticalAlignment="Stretch">
                        <TextBlock VerticalAlignment="Center" Text="拼" />
                    </StackPanel>
                </Grid>
                <Grid Name="TbRbStatusArea">
                    <Button
                        Name="Button_TbRbStatusArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <StackPanel
                        Name="TbRbStatusAreaStk"
                        Margin="6,0,6,0"
                        VerticalAlignment="Stretch">
                        <TextBlock VerticalAlignment="Center" Text="控制中心" />
                    </StackPanel>
                    <Button
                        Name="Button_TbRbStatusArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbStatusArea_Front_Click"
                        CornerRadius="8"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbTimeArea" Width="76">
                    <Button
                        Name="Button_TbRbTimeArea_Behind"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        CornerRadius="8"
                        IsTabStop="False" />
                    <TextBlock
                        Name="TbRbTime"
                        Margin="0,0,11,25"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        FontFamily="HarmonyOS Sans SC"
                        FontSize="12"
                        Text="00:00" />
                    <TextBlock
                        Name="TbRbDate"
                        Margin="0,0,11,9"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        FontFamily="HarmonyOS Sans SC"
                        FontSize="12"
                        Text="2026/1/1" />
                    <Button
                        Name="Button_TbRbTimeArea_Front"
                        Margin="2,3,2,3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbTimeArea_Front_Click"
                        CornerRadius="8"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.4" />
                </Grid>
                <Grid Name="TbRbShowDskArea" Width="8">
                    <Button
                        Name="Button_TbRbShowDskArea_Front"
                        Margin="0,2,-1,-1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_TbRbShowDskArea_Front_Click"
                        CornerRadius="0"
                        FontFamily="HarmonyOS Sans SC"
                        Opacity="0.8"
                        ToolTipService.ToolTip="显示桌面" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
