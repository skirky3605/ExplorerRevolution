<Page
    x:Class="ExplorerRevolution.UI.TaskBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ExplorerRevolution.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="{ThemeResource SystemControlDisabledTransparentBrush}">
        <Grid Name="TaskBarGrid" Loaded="TaskBarGrid_Loaded" Background="{ThemeResource SystemControlAcrylicElementMediumHighBrush}" CornerRadius="1">
            <Button Background="Transparent" IsEnabled="False" CornerRadius="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Height="50" Margin="-2,0,-2,-2"/>
            <StackPanel Name="TaskBarStack" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="48">
                <StackPanel.Transitions >
                    <TransitionCollection>
                        <RepositionThemeTransition/>
                    </TransitionCollection>
                </StackPanel.Transitions>
                
            </StackPanel>
        </Grid>
    </Grid>
</Page>
